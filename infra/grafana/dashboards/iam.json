  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Login attempts/sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chetana_iam_login_attempts_total[$__rate_interval])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Login failure rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chetana_iam_login_attempts_total{outcome!=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(chetana_iam_login_attempts_total[$__rate_interval])), 1)",
          "legendFormat": "fail rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Token issue p95 latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(chetana_iam_token_issue_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Active sessions",
      "type": "timeseries",
      "targets": [
        { "expr": "chetana_iam_sessions_active", "legendFormat": "active" }
      ]
    }
  ],
