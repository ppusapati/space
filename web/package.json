{
  "name": "@samavāya/web-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.13.0",
  "scripts": {
    "postinstall": "pnpm --filter @p9e.in/configs build",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:shell": "turbo run dev --filter=@samavaya/shell",
    "dev:proxy": "tsx proxy/dev-proxy.ts",
    "dev:all": "turbo run dev --filter=@samavāya/shell --filter=@samavāya/identity --filter=@samavāya/masters --filter=@samavāya/finance",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{js,ts,svelte,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,svelte,json,css,md}\"",
    "wasm:build": "turbo run wasm:build --filter=@samavāya/wasm",
    "wasm:build:dev": "turbo run wasm:build:dev --filter=@samavāya/wasm",
    "wasm:clean": "rimraf packages/wasm/pkg packages/wasm/target",
    "proto:generate": "turbo run generate --filter=@samavāya/proto",
    "proto:clean": "turbo run generate:clean --filter=@samavāya/proto"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^22.10.0",
    "cross-env": "^10.1.0",
    "http-proxy": "^1.18.1",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
