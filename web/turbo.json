{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "wasm:build": {
      "inputs": ["crates/**/*.rs", "crates/**/Cargo.toml", "Cargo.toml"],
      "outputs": ["pkg/**"],
      "cache": true
    },
    "wasm:build:dev": {
      "inputs": ["crates/**/*.rs", "crates/**/Cargo.toml", "Cargo.toml"],
      "outputs": ["pkg/**"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".svelte-kit/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
