{
  "name": "@samavāya/i18n",
  "version": "1.0.0",
  "description": "Internationalization for Samavāya ERP — multi-language support for 4 verticals (agriculture, manufacturing, water, construction)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./locales/*": "./locales/*.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "locales"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": ["i18n", "internationalization", "svelte", "samavāya", "erp", "multilingual"]
}
