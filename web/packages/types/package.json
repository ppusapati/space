{
  "name": "@chetana/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for Chetana ERP - single source of truth for all type definitions",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@chetana/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "keywords": ["typescript", "types", "Chetana", "erp"]
}
