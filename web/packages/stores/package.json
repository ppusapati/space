{
  "name": "@samavāya/stores",
  "version": "0.0.1",
  "description": "State management stores for samavāya ERP",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./global": "./src/global/index.ts",
    "./factories": "./src/factories/index.ts",
    "./modules": "./src/modules/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@samavāya/core": "workspace:*",
    "@samavāya/proto": "workspace:*",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false
}
