{
  "name": "@samavāya/api",
  "version": "0.0.1",
  "description": "ConnectRPC API client for samavāya ERP",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./interceptors": "./src/interceptors/index.ts",
    "./utils": "./src/utils/index.ts",
    "./services": "./src/services/index.ts",
    "./services/*": "./src/services/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0",
    "@samavāya/proto": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "samavāya",
    "erp",
    "api",
    "connectrpc",
    "grpc",
    "protobuf"
  ],
  "license": "MIT"
}
