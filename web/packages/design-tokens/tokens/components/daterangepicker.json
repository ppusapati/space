        "base": {
          "value": "w-full px-3 py-2 text-left text-sm rounded transition-colors"
        },
        "state": {
          "default": {
            "value": "text-color-neutral-700 hover:bg-color-neutral-100"
          },
          "selected": {
            "value": "bg-color-brand-primary-50 text-color-brand-primary-700"
          }
        }
      }
