      },
      "title": {
        "value": "font-semibold text-color-neutral-900"
      },
      "weekdays": {
        "value": "grid grid-cols-7 mb-2"
      },
      "weekday": {
        "value": "text-center text-xs font-medium text-color-neutral-500 py-2"
      },
      "days": {
        "value": "grid grid-cols-7 gap-1"
      },
      "day": {
        "base": {
          "value": "w-9 h-9 flex items-center justify-center rounded text-sm transition-all duration-150 cursor-pointer"
        },
        "state": {
          "default": {
            "value": "text-color-neutral-700 hover:bg-color-neutral-100"
          },
          "today": {
            "value": "font-bold text-color-brand-primary-600"
          },
          "selected": {
            "value": "bg-color-brand-primary-500 text-color-neutral-white"
          },
          "inRange": {
            "value": "bg-color-brand-primary-100"
          },
          "rangeStart": {
            "value": "bg-color-brand-primary-500 text-color-neutral-white rounded-l-full"
          },
          "rangeEnd": {
            "value": "bg-color-brand-primary-500 text-color-neutral-white rounded-r-full"
          },
          "disabled": {
            "value": "text-color-neutral-300 cursor-not-allowed"
          },
          "outside": {
            "value": "text-color-neutral-400"
          }
        }
      }
    },
    "presets": {
      "container": {
        "value": "border-l border-color-neutral-200 p-4 min-w-[160px]"
      },
      "label": {
        "value": "text-xs font-semibold text-color-neutral-500 uppercase mb-2"
      },
      "list": {
        "value": "space-y-1"
      },
