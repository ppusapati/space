        "value": "flex items-center justify-between p-4 border-t border-color-neutral-200"
      },
      "selected": {
        "value": "text-sm text-color-neutral-600"
      }
    },
    "label": {
      "base": {
        "value": "block text-sm font-medium text-color-neutral-700 mb-1"
      }
    },
    "required": {
      "value": "text-color-semantic-error-500 ml-1"
    },
    "helper": {
      "base": {
        "value": "mt-1 text-sm"
      },
      "state": {
        "default": {
          "value": "text-color-neutral-500"
        },
        "error": {
          "value": "text-color-semantic-error-500"
        }
      }
    }
