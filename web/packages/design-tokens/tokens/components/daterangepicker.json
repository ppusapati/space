{
  "daterangepicker": {
    "container": {
      "base": {
        "value": "relative"
      }
    },
    "trigger": {
      "base": {
        "value": "flex items-center justify-between w-full border rounded-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
      },
      "size": {
        "sm": {
          "value": "px-3 py-1.5 text-sm"
        },
        "md": {
          "value": "px-3 py-2 text-base"
        },
        "lg": {
          "value": "px-4 py-3 text-lg"
        }
      },
      "state": {
        "default": {
          "value": "border-color-neutral-300 bg-color-neutral-white focus:ring-color-brand-primary-500"
        },
        "error": {
          "value": "border-color-semantic-error-500 focus:ring-color-semantic-error-500"
        },
        "open": {
          "value": "ring-2 ring-color-brand-primary-500"
        }
      }
    },
    "placeholder": {
      "value": "text-color-neutral-400"
    },
    "separator": {
      "value": "mx-2 text-color-neutral-400"
    },
    "icon": {
      "base": {
        "value": "text-color-neutral-400"
      },
      "size": {
        "value": "w-5 h-5"
      }
    },
    "panel": {
      "base": {
        "value": "absolute z-dropdown mt-1 bg-color-neutral-white border border-color-neutral-200 rounded-lg shadow-lg"
      },
      "dual": {
        "value": "flex"
      }
    },
    "calendar": {
