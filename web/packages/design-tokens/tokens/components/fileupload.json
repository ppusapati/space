{
  "fileupload": {
    "container": {
      "base": {
        "value": "relative"
      }
    },
    "dropzone": {
      "base": {
        "value": "flex flex-col items-center justify-center border-2 border-dashed rounded-lg transition-all duration-200 cursor-pointer"
      },
      "size": {
        "sm": {
          "value": "p-4 min-h-[100px]"
        },
        "md": {
          "value": "p-6 min-h-[150px]"
        },
        "lg": {
          "value": "p-8 min-h-[200px]"
        }
      },
      "state": {
        "default": {
          "value": "border-color-neutral-300 bg-color-neutral-50 hover:border-color-brand-primary-400 hover:bg-color-brand-primary-50"
        },
        "dragOver": {
          "value": "border-color-brand-primary-500 bg-color-brand-primary-50"
        },
        "error": {
          "value": "border-color-semantic-error-500 bg-color-semantic-error-50"
        },
        "disabled": {
          "value": "opacity-50 cursor-not-allowed"
        }
      }
    },
    "icon": {
      "base": {
        "value": "text-color-neutral-400"
      },
      "size": {
        "sm": {
          "value": "w-8 h-8"
        },
        "md": {
          "value": "w-12 h-12"
        },
        "lg": {
          "value": "w-16 h-16"
        }
      }
    },
    "text": {
      "primary": {
        "value": "text-color-neutral-700 font-medium mt-2"
      },
      "secondary": {
        "value": "text-sm text-color-neutral-500 mt-1"
      },
      "link": {
        "value": "text-color-brand-primary-500 hover:text-color-brand-primary-600 font-medium"
      }
    },
    "input": {
      "hidden": {
        "value": "sr-only"
      }
    },
    "preview": {
      "container": {
        "value": "mt-4 space-y-2"
      },
      "item": {
        "base": {
          "value": "flex items-center gap-3 p-3 bg-color-neutral-50 border border-color-neutral-200 rounded-lg"
        },
        "uploading": {
          "value": "border-color-brand-primary-300"
        },
        "error": {
          "value": "border-color-semantic-error-300 bg-color-semantic-error-50"
        },
        "success": {
          "value": "border-color-semantic-success-300"
        }
      },
      "thumbnail": {
        "value": "w-10 h-10 rounded object-cover bg-color-neutral-200"
      },
      "info": {
        "name": {
          "value": "text-sm font-medium text-color-neutral-700 truncate"
        },
        "size": {
          "value": "text-xs text-color-neutral-500"
        }
      },
      "progress": {
        "track": {
          "value": "w-full h-1 bg-color-neutral-200 rounded-full overflow-hidden"
        },
        "bar": {
          "value": "h-full bg-color-brand-primary-500 transition-all duration-300"
        }
      },
      "actions": {
        "button": {
          "value": "p-1 text-color-neutral-400 hover:text-color-neutral-600 rounded focus:outline-none focus:ring-2 focus:ring-color-brand-primary-500"
        }
      }
    },
    "label": {
      "base": {
        "value": "block text-sm font-medium text-color-neutral-700 mb-2"
      }
    },
    "helper": {
      "base": {
        "value": "mt-2 text-sm text-color-neutral-500"
      },
      "error": {
        "value": "text-color-semantic-error-500"
      }
    }
  }
}
